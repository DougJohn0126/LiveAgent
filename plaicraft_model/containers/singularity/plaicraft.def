Bootstrap: docker
From: nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04

%files
    requirements.txt /opt/requirements.txt

%environment
    export LC_ALL=C
    export TORCH_CUDA_ARCH_LIST="7.0;7.5;8.0;8.6;9.0+PTX"
    export CUDA_HOME=/usr/local/cuda
    export PATH=/opt/venv/bin:$PATH

%post
    export DEBIAN_FRONTEND=noninteractive
    
    # 1. Install system dependencies and native Ubuntu RDMA stack
    # (libnccl2 and libnccl-dev are intentionally excluded to preserve NVIDIA's held optimizations)
    apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common wget curl gpg rsync ca-certificates \
        git build-essential ninja-build cmake pkg-config \
        libaio-dev libnuma-dev numactl ffmpeg libsndfile1 libglib2.0-0 libgl1 \
        libibverbs1 ibverbs-providers ibverbs-utils rdma-core \
        python3.12 python3.12-dev python3.12-venv
        
    # 2. Create virtual environment
    python3.12 -m venv /opt/venv
    . /opt/venv/bin/activate

    # 3. Upgrade pip and build tools
    pip install --no-cache-dir -U pip setuptools wheel

    # 4. Install PyTorch 2.5.1 (stable version tuned for CUDA 12.4)
    pip install --no-cache-dir \
        torch==2.5.1+cu124 \
        torchvision==0.20.1+cu124 \
        torchaudio==2.5.1+cu124 \
        --index-url https://download.pytorch.org/whl/cu124

    # 5. Force Triton 3.1.0 (avoids the LLVM SLPVectorizer crash on H100s)
    pip install --no-cache-dir triton==3.1.0

    # 6. Install dependencies
    pip install --no-cache-dir -r /opt/requirements.txt

    pip install --no-cache-dir jupyterlab ipykernel

%runscript
    . /opt/venv/bin/activate
    exec "$@"