# Environment configuration for plaicraft-model-pi0
#### Copy this file to .env and update paths according to your setup !!!!!

# ==================== PROJECT PATHS ====================
# Root directory of the plaicraft-model-pi0 project
export PROJECT_ROOT=""

# ==================== DATA PATHS ====================
# Path to the processed dataset
export DATASET_PATH=""

# Path to training metadata database
export TRAINING_METADATA_DB_PATH=""

# Path to validation metadata database
export VALIDATION_METADATA_DB_PATH=""

# Path to evaluation metadata database
export EVALUATION_METADATA_DB_PATH=""

# ==================== CONTAINER PATHS ====================
# Full path to Singularity/container image (.sif)
export CONTAINER_IMAGE_PATH=""

# ==================== CHECKPOINT PATHS ====================
# Path to keypress autoencoder checkpoint
export KEYPRESS_CHECKPOINT_PATH="${PROJECT_ROOT}/keypress_autoencoder/checkpoints/keyencoder_16_5_best_checkpoint.pt"

# Temporary directory for job-specific files on compute-node scratch
export TMPDIR="${SLURM_TMPDIR:-/tmp}"

# ==================== MODEL CACHES ====================
# HuggingFace model cache (for VAE, Encodec, Wav2Vec2)
# Run scripts/download_models.py to predownload models to this location
export HF_HOME="${PROJECT_ROOT}/.cache/huggingface"

# PyTorch model cache (for VGG16 used in LPIPS metric)
# Run scripts/download_models.py to predownload models to this location
export TORCH_HOME="${PROJECT_ROOT}/.cache/torch"

# ==================== REPOSITORY URLS ====================
# Git repository for plaicraft-diffusion-model (used in validation scripts)
export PLAICRAFT_DIFFUSION_MODEL_REPO="git@github.com:plai-group/plaicraft-diffusion-model.git"
